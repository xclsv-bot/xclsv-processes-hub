generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String              @id @default(uuid())
  email           String              @unique
  name            String
  avatarUrl       String?
  role            UserRole            @default(VIEWER)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?
  auditLogs       AuditLog[]
  comments        Comment[]
  ownedProcesses  Process[]           @relation("ProcessOwner")
  permissions     ProcessPermission[]
  createdVersions ProcessVersion[]    @relation("VersionCreator")
  refreshTokens   RefreshToken[]
  activities      UserActivity[]

  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Process {
  id                      String              @id @default(uuid())
  title                   String
  slug                    String              @unique
  description             String?
  content                 String?
  status                  ProcessStatus       @default(DRAFT)
  area                    ProcessArea
  currentVersion          Int                 @default(1)
  ownerId                 String
  verificationDueAt       DateTime?
  verificationStatus      VerificationStatus  @default(PENDING)
  lastVerifiedAt          DateTime?
  verificationCadenceDays Int                 @default(90)
  metadata                Json?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  publishedAt             DateTime?
  deletedAt               DateTime?
  comments                Comment[]
  owner                   User                @relation("ProcessOwner", fields: [ownerId], references: [id])
  embedding               ProcessEmbedding?
  permissions             ProcessPermission[]
  relatedFrom             ProcessRelation[]   @relation("RelatedFrom")
  relatedTo               ProcessRelation[]   @relation("RelatedTo")
  tags                    ProcessTag[]
  versions                ProcessVersion[]

  @@index([ownerId])
  @@index([area])
  @@index([status])
  @@index([slug])
  @@index([deletedAt])
  @@index([verificationDueAt])
  @@index([verificationStatus])
}

model ProcessVersion {
  id            String   @id @default(uuid())
  processId     String
  versionNumber Int
  title         String
  content       String
  snapshot      Json
  changeNotes   String?
  createdById   String
  createdAt     DateTime @default(now())
  createdBy     User     @relation("VersionCreator", fields: [createdById], references: [id])
  process       Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@unique([processId, versionNumber])
  @@index([processId])
  @@index([createdById])
}

model ProcessPermission {
  id         String   @id @default(uuid())
  processId  String
  userId     String
  canView    Boolean  @default(true)
  canEdit    Boolean  @default(false)
  canDelete  Boolean  @default(false)
  canPublish Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  process    Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([processId, userId])
  @@index([processId])
  @@index([userId])
}

model ProcessRelation {
  id            String   @id @default(uuid())
  fromProcessId String
  toProcessId   String
  relationType  String
  createdAt     DateTime @default(now())
  fromProcess   Process  @relation("RelatedFrom", fields: [fromProcessId], references: [id], onDelete: Cascade)
  toProcess     Process  @relation("RelatedTo", fields: [toProcessId], references: [id], onDelete: Cascade)

  @@unique([fromProcessId, toProcessId])
  @@index([fromProcessId])
  @@index([toProcessId])
}

model Tag {
  id          String       @id @default(uuid())
  name        String       @unique
  slug        String       @unique
  color       String?
  description String?
  createdAt   DateTime     @default(now())
  processes   ProcessTag[]

  @@index([slug])
}

model ProcessTag {
  id        String   @id @default(uuid())
  processId String
  tagId     String
  createdAt DateTime @default(now())
  process   Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([processId, tagId])
  @@index([processId])
  @@index([tagId])
}

model Comment {
  id         String    @id @default(uuid())
  processId  String
  userId     String
  content    String
  parentId   String?
  isResolved Boolean   @default(false)
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  parent     Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies    Comment[] @relation("CommentReplies")
  process    Process   @relation(fields: [processId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@index([processId])
  @@index([userId])
  @@index([parentId])
  @@index([deletedAt])
}

model AuditLog {
  id         String         @id @default(uuid())
  entityType String
  entityId   String
  operation  AuditOperation
  userId     String
  changes    Json
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime       @default(now())
  user       User           @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([operation])
}

model UserActivity {
  id           String   @id @default(uuid())
  userId       String
  activityType String
  entityType   String?
  entityId     String?
  metadata     Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Media {
  id           String    @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  thumbnailUrl String?
  uploadedById String?
  metadata     Json?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  @@index([uploadedById])
  @@index([mimeType])
  @@index([deletedAt])
}

model DefaultRole {
  id          String   @id @default(uuid())
  name        String   @unique
  permissions Json
  description String?
  createdAt   DateTime @default(now())
}

model ProcessEmbedding {
  id        String   @id @default(uuid())
  processId String   @unique
  embedding Float[]
  model     String   @default("text-embedding-ada-002")
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  process   Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@index([processId])
}

enum UserRole {
  ADMIN
  MANAGER
  EDITOR
  VIEWER
}

enum ProcessStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum ProcessArea {
  PARTNERSHIPS
  EVENT_SCHEDULING
  EVENT_MARKETPLACE
  AMBASSADOR_RECRUITMENT
  AMBASSADOR_MANAGEMENT
  OPERATIONS
  CLIENT_MANAGEMENT
  FINANCES
  AFFILIATE_MANAGEMENT
  PRODUCT_DEVELOPMENT
}

enum AuditOperation {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  ARCHIVE
  RESTORE
}

enum VerificationStatus {
  PENDING
  VERIFIED
  OVERDUE
}
