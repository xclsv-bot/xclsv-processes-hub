generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String              @id @default(uuid())
  email           String              @unique
  name            String
  passwordHash    String?
  avatarUrl       String?
  role            UserRole            @default(VIEWER)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?
  auditLogs       AuditLog[]
  comments        Comment[]
  ownedProcesses  Process[]           @relation("ProcessOwner")
  permissions     ProcessPermission[]
  createdVersions ProcessVersion[]    @relation("VersionCreator")
  refreshTokens   RefreshToken[]
  activities      UserActivity[]
  uploadedMedia      Media[]             @relation("MediaUploader")
  stepOwnerships     StepOwner[]
  mentionedInComments CommentMention[]   @relation("MentionedInComments")
  commentEdits       CommentEdit[]       @relation("CommentEdits")

  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model Process {
  id                      String              @id @default(uuid())
  title                   String
  slug                    String              @unique
  description             String?             @db.Text
  content                 String?             @db.Text
  type                    ProcessType         @default(PROCESS)
  status                  ProcessStatus       @default(DRAFT)
  area                    ProcessArea
  currentVersion          Int                 @default(1)
  ownerId                 String
  verificationDueAt       DateTime?
  verificationStatus      VerificationStatus  @default(PENDING)
  lastVerifiedAt          DateTime?
  verificationCadenceDays Int                 @default(90)
  metadata                Json?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  publishedAt             DateTime?
  deletedAt               DateTime?
  comments                Comment[]
  owner                   User                @relation("ProcessOwner", fields: [ownerId], references: [id])
  embedding               ProcessEmbedding?
  permissions             ProcessPermission[]
  relatedFrom             ProcessRelation[]   @relation("RelatedFrom")
  relatedTo               ProcessRelation[]   @relation("RelatedTo")
  stepDocuments           StepDocument[]      @relation("StepDocuments")
  tags                    ProcessTag[]
  versions                ProcessVersion[]
  media                   Media[]
  steps                   ProcessStep[]

  @@index([ownerId])
  @@index([area])
  @@index([status])
  @@index([type])
  @@index([slug])
  @@index([deletedAt])
  @@index([verificationDueAt])
  @@index([verificationStatus])
}

model ProcessVersion {
  id          String   @id @default(uuid())
  processId   String
  version     Int
  title       String
  content     String   @db.Text
  snapshot    Json?
  changeNotes String?
  createdById String
  createdAt   DateTime @default(now())
  createdBy   User     @relation("VersionCreator", fields: [createdById], references: [id])
  process     Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@unique([processId, version])
  @@index([processId])
  @@index([createdById])
}

model ProcessStep {
  id          String      @id @default(uuid())
  processId   String
  sequence    Int
  title       String
  description String?     @db.Text
  isHandoff   Boolean     @default(false)
  metadata    Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  process     Process     @relation(fields: [processId], references: [id], onDelete: Cascade)
  owners      StepOwner[]
  tools       StepTool[]
  documents   StepDocument[]

  @@unique([processId, sequence])
  @@index([processId])
  @@index([sequence])
  @@index([deletedAt])
}

model Tool {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  icon        String?
  color       String?
  description String?
  url         String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  steps       StepTool[]

  @@index([slug])
}

model StepOwner {
  id        String      @id @default(uuid())
  stepId    String
  userId    String
  createdAt DateTime    @default(now())
  step      ProcessStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([stepId, userId])
  @@index([stepId])
  @@index([userId])
}

model StepTool {
  id        String      @id @default(uuid())
  stepId    String
  toolId    String
  createdAt DateTime    @default(now())
  step      ProcessStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  tool      Tool        @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([stepId, toolId])
  @@index([stepId])
  @@index([toolId])
}

model ProcessPermission {
  id         String   @id @default(uuid())
  processId  String
  userId     String
  canView    Boolean  @default(true)
  canEdit    Boolean  @default(false)
  canDelete  Boolean  @default(false)
  canPublish Boolean  @default(false)
  canVerify  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  process    Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([processId, userId])
  @@index([processId])
  @@index([userId])
}

model ProcessRelation {
  id            String   @id @default(uuid())
  fromProcessId String
  toProcessId   String
  relationType  String
  createdAt     DateTime @default(now())
  fromProcess   Process  @relation("RelatedFrom", fields: [fromProcessId], references: [id], onDelete: Cascade)
  toProcess     Process  @relation("RelatedTo", fields: [toProcessId], references: [id], onDelete: Cascade)

  @@unique([fromProcessId, toProcessId])
  @@index([fromProcessId])
  @@index([toProcessId])
}

model Tag {
  id          String       @id @default(uuid())
  name        String       @unique
  slug        String       @unique
  color       String?
  description String?
  createdAt   DateTime     @default(now())
  processes   ProcessTag[]

  @@index([slug])
}

model ProcessTag {
  id        String   @id @default(uuid())
  processId String
  tagId     String
  createdAt DateTime @default(now())
  process   Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([processId, tagId])
  @@index([processId])
  @@index([tagId])
}

model Comment {
  id          String          @id @default(uuid())
  processId   String
  userId      String
  content     String          @db.Text
  parentId    String?
  isResolved  Boolean         @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  parent      Comment?        @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[]       @relation("CommentReplies")
  process     Process         @relation(fields: [processId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id])
  mentions    CommentMention[]
  editHistory CommentEdit[]

  @@index([processId])
  @@index([userId])
  @@index([parentId])
  @@index([deletedAt])
}

model CommentMention {
  id              String   @id @default(uuid())
  commentId       String
  mentionedUserId String
  createdAt       DateTime @default(now())
  comment         Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUser   User     @relation("MentionedInComments", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([commentId, mentionedUserId])
  @@index([commentId])
  @@index([mentionedUserId])
}

model CommentEdit {
  id              String   @id @default(uuid())
  commentId       String
  previousContent String   @db.Text
  editedById      String
  createdAt       DateTime @default(now())
  comment         Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  editedBy        User     @relation("CommentEdits", fields: [editedById], references: [id])

  @@index([commentId])
  @@index([editedById])
  @@index([createdAt])
}

model AuditLog {
  id         String         @id @default(uuid())
  entityType String
  entityId   String
  operation  AuditOperation
  userId     String
  changes    Json
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime       @default(now())
  user       User           @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([operation])
}

model UserActivity {
  id           String   @id @default(uuid())
  userId       String
  activityType String
  entityType   String?
  entityId     String?
  metadata     Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Media {
  id           String    @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  thumbnailUrl String?
  uploadedById String?
  uploadedBy   User?     @relation("MediaUploader", fields: [uploadedById], references: [id])
  processId    String?
  process      Process?  @relation(fields: [processId], references: [id], onDelete: SetNull)
  metadata     Json?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  @@index([uploadedById])
  @@index([processId])
  @@index([mimeType])
  @@index([deletedAt])
}

model DefaultRole {
  id          String   @id @default(uuid())
  name        String   @unique
  permissions Json
  description String?
  createdAt   DateTime @default(now())
}

model ProcessEmbedding {
  id        String   @id @default(uuid())
  processId String   @unique
  embedding Float[]
  model     String   @default("text-embedding-ada-002")
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  process   Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@index([processId])
}

enum UserRole {
  ADMIN
  MANAGER
  EDITOR
  VIEWER
}

enum ProcessStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum ProcessArea {
  EVENTS
  INFLUENCER
  PARTNERS
  CRM
  OPERATIONS
  FINANCE
  HR
  GENERAL
}

enum AuditOperation {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  ARCHIVE
  RESTORE
  VERIFY
  MARK_NEEDS_REVIEW
  TRANSFER_OWNERSHIP
  AI_USAGE
}

enum VerificationStatus {
  PENDING
  VERIFIED
  OVERDUE
  NEEDS_REVIEW
}

enum ProcessType {
  PROCESS
  DOCUMENT
}

model StepDocument {
  id              String      @id @default(uuid())
  stepId          String
  documentId      String      // References a Process that serves as a document
  label           String?     // Optional display label
  createdAt       DateTime    @default(now())
  
  step            ProcessStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  document        Process     @relation("StepDocuments", fields: [documentId], references: [id], onDelete: Cascade)
  
  @@unique([stepId, documentId])
  @@index([stepId])
  @@index([documentId])
}
