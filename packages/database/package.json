    "dev": "tsc --watch"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prisma": "^5.22.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
